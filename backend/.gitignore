# ─────────────────────────────────────────────────────────────
# Python / uv backend
# ─────────────────────────────────────────────────────────────

# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments (managed by uv — never commit)
.venv/
venv/
env/
ENV/

# uv keeps uv.lock committed for reproducible installs (do NOT ignore it)

# Secrets / local env — keep the sample committed
.env
.env.*
!.env.sample

# Test & tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
coverage.xml
htmlcov/

# Packaging / build artifacts
*.egg-info/
.eggs/
dist/
build/

# Logs
*.log

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
