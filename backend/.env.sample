# Strata backend configuration.
# Local dev: copy to `.env` and fill in. Hosted (Render/…): set these as the
# service's environment variables instead — never commit real secrets.

# ── Database ─────────────────────────────────────────────────────────────────
# Local: postgresql+asyncpg://user:pass@localhost:5433/construction_db
# Hosted (Neon): paste the connection string as-is — the app rewrites the scheme
# to +asyncpg and translates sslmode automatically (see database/engine.py).
# Use Neon's DIRECT connection string (not the -pooler one).
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5433/construction_db
DB_ECHO=False

# ── App ──────────────────────────────────────────────────────────────────────
SECRET_KEY=your_64char_random_key
ENVIRONMENT=development            # set "production" when deployed (hides /docs)
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# Where the SPA is served — used for CORS and for links in OTP/invite/dispatch
# emails. Hosted: set to your Vercel URL, e.g. https://strata.vercel.app
FRONTEND_URL=http://localhost:3000

# ── File uploads ─────────────────────────────────────────────────────────────
# LocalStorage root. NOTE: hosted free tiers have EPHEMERAL disk — uploaded PDFs
# do not survive a restart/redeploy. Swap to object storage for persistence.
UPLOAD_DIR=uploads
MAX_UPLOAD_BYTES=26214400

# ── AI (analyst agent + RAG) ─────────────────────────────────────────────────
# "ollama" (default) uses a local Ollama server. "openai" calls a hosted
# OpenAI-compatible API (Google Gemini by default) for both chat and embeddings.
AI_PROVIDER=ollama

# Local Ollama (used when AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Hosted LLM (used when AI_PROVIDER=openai). Defaults target Google Gemini's
# OpenAI-compatible endpoint — one AI Studio key covers chat + embeddings.
# Other providers (Groq/Cerebras/Mistral/OpenRouter) work by changing the URL/model.
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_MODEL=gemini-2.5-flash
EMBED_MODEL=gemini-embedding-001
LLM_API_KEY=

# ── Email (Gmail SMTP; best-effort — failures never block a request) ─────────
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_16char_app_password
MAIL_FROM=your_gmail@gmail.com
MAIL_FROM_NAME=Strata
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
