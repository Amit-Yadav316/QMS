# Base URL for all API requests (see src/api/client.ts).
# Dev: leave as the relative path below — Vite proxies /api -> http://localhost:8000.
# Prod (Vercel): set this in the Vercel project's Environment Variables to the
# full backend URL, e.g. https://strata-backend.onrender.com/api/v1
# (Vite inlines VITE_* at BUILD time, so changing it requires a redeploy.)
VITE_API_BASE_URL=/api/v1
